# =============================================================
# NIYA TEMPLATE — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# =============================================================

# ── Auth ──────────────────────────────────────────────────────
# Set to "true" to enable the full auth flow (login, signup, JWT, etc).
# Default: false — all routes are public, a guest session is used.
NEXT_PUBLIC_AUTH_ENABLED=false

# Backend API base URL (only needed when AUTH_ENABLED=true)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string.
# If set, the app uses PostgreSQL via `pg`.
# If NOT set, the app falls back to a local SQLite file (./local.db).
#
# Run the setup script once after configuring:
#   node lib/db/scripts/run-setup.mjs
#
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Disable SSL for local PG instances (e.g. Docker). Default: SSL enabled.
# DATABASE_SSL=false

# Override the SQLite file path (default: ./local.db)
# SQLITE_DB_PATH=./local.db

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=MyApp
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional: News APIs (for TypePulse) ───────────────────────
# NEWSAPI_KEY=your_newsapi_key_here
# GNEWS_KEY=your_gnews_key_here
